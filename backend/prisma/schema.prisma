generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  chunks    Chunk[]
}

model Chunk {
  id         String                 @id @default(uuid())
  documentId String
  document   Document               @relation(fields: [documentId], references: [id])
  content    String
  embedding  Unsupported("vector(1536)")
  chunkIndex Int
  createdAt  DateTime               @default(now())

  @@index([documentId])
}

model EvalCase {
  id             String   @id @default(uuid())
  question       String
  expectedAnswer String
  createdAt      DateTime @default(now())
}

model EvalRun {
  id           String   @id @default(uuid())
  evalCaseId   String
  actualAnswer String
  score        Float
  latencyMs    Int
  passed       Boolean
  createdAt    DateTime @default(now())
}
